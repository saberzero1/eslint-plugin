{
	"name": "eslint-plugin-obsidianmd",
	"version": "0.2.9",
	"description": "Validates guidelines for Obsidian plugins",
	"license": "MIT",
	"author": "Dynalist Inc.",
	"homepage": "https://obsidian.md",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/obsidianmd/eslint-plugin.git"
	},
	"keywords": [
		"eslint",
		"eslintplugin",
		"eslint-plugin",
		"obsidian",
		"obsdmd"
	],
	"main": "dist/lib/index.js",
	"scripts": {
		"build": "tsc",
		"test": "mocha",
		"init:eslint-docs": "eslint-doc-generator --init-rule-docs || exit 0",
		"update:eslint-docs": "eslint-doc-generator",
		"check:eslint-docs": "eslint-doc-generator --check"
	},
	"bin": {
		"eslint-plugin-obsidian": "dist/lib/index.js"
	},
	"files": [
		"dist/**"
	],
	"types": "dist/lib/index.d.ts",
	"dependencies": {
		"@eslint/config-helpers": "^0.4.2",
		"@eslint/js": "^9.30.1",
		"@eslint/json": "0.14.0",
		"@microsoft/eslint-plugin-sdl": "^1.1.0",
		"@types/eslint": "9.6.1",
		"@types/node": "20.12.12",
		"@typescript-eslint/types": "^8.33.1",
		"@typescript-eslint/utils": "^8.33.1",
		"eslint": ">=9.0.0",
		"eslint-plugin-depend": "1.3.1",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-json-schema-validator": "5.1.0",
        "eslint-plugin-no-unsanitized": "^4.1.5",
		"eslint-plugin-security": "2.1.1",
		"globals": "14.0.0",
		"obsidian": "1.12.3",
        "semver": "^7.7.4",
		"typescript": "5.4.5",
		"typescript-eslint": "^8.35.1"
	},
	"devDependencies": {
		"@eslint/compat": "1.3.1",
		"@types/mocha": "10.0.6",
        "@types/semver": "^7.7.1",
		"@typescript-eslint/eslint-plugin": "^8.33.1",
		"@typescript-eslint/parser": "^8.33.1",
		"@typescript-eslint/rule-tester": "^8.33.1",
		"builtin-modules": "3.3.0",
		"esbuild": "^0.27.4",
		"eslint-doc-generator": "3.3.2",
		"mocha": "^11.7.5",
		"ts-node": "10.9.2",
		"tsx": "4.19.4"
	},
	"overrides": {
		"mocha": {
			"diff": "^8.0.4",
			"serialize-javascript": "^7.0.5"
		}
	},
	"engines": {
		"node": ">= 18"
	},
	"peerDependencies": {
		"@eslint/js": "^9.30.1",
		"@eslint/json": "0.14.0",
		"eslint": ">=9.0.0",
		"obsidian": "1.8.7",
		"typescript-eslint": "^8.35.1"
	},
	"type": "module",
	"eslint-doc-generator": {
		"configEmoji": [
			[
				"recommendedWithLocalesEn",
				"🇬🇧"
			]
		]
	}
}
